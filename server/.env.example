# Configuración del Puerto
PORT=3001

# Base de Datos (PostgreSQL via Prisma)
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST:PUERTO/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USUARIO:PASSWORD@HOST:PUERTO/DATABASE"

# Supabase (Gestión de Auth y Archivos)
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_ANON_KEY="tu-anon-key-aqui"

# Mercado Pago (Pasarela de Pagos)
MP_ACCESS_TOKEN="APP_USR-..."
MP_CLIENT_ID="tu-client-id"
MP_PUBLIC_KEY="APP_USR-..."

# Email Service (Resend)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="contacto@tudominio.com"

# Redes y Notificaciones
FRONTEND_URL="http://localhost:5173"
CONTACT_EMAIL="admin@tudominio.com"
